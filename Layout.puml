@startuml

class Book {
  - title : String
  - author : String
  - isAvailable : boolean
  + Book(title : String, author : String)
  + getTitle() : String
  + setTitle(title : String) : void
  + getAuthor() : String
  + setAuthor(author : String) : void
  + isAvailable() : boolean
  + setAvailable(available : boolean) : void
  + toString() : String
}

class Library {
  - books : ArrayList<Book>
  + Library()
  + addBook(book : Book) : void
  + displayAllBooks() : void
  + borrowBook(title : String) : void
  + returnBook(title : String) : void
  + searchBook(title : String) : void
}

class Main {
  + main(args : String[]) : void
}

Library "1" --> "*" Book : manages
Main --> Library : uses
Main --> Book : creates

@enduml